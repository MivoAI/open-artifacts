{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-artifacts.dev/schemas/artifact-package/0.1.json",
  "title": "Open Artifacts package v0.1 prototype",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactVersion",
    "id",
    "revision",
    "renderer",
    "inputSchema",
    "capabilities",
    "provenance",
    "editPolicy",
    "data"
  ],
  "properties": {
    "artifactVersion": {
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "version"],
      "properties": {
        "kind": {
          "const": "template"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputSchema": {
      "type": "string",
      "format": "uri-reference"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "code"],
      "properties": {
        "network": {
          "enum": ["none", "declared"]
        },
        "code": {
          "enum": ["trusted-components", "sandbox"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator", "createdAt"],
      "properties": {
        "generator": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "editPolicy": {
      "enum": ["patchable", "replace-only"]
    },
    "data": {
      "$ref": "#/$defs/decisionBriefData"
    }
  },
  "$defs": {
    "decisionBriefData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "metrics", "insights", "sources", "timeline", "actions"],
      "properties": {
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "kind", "title", "question", "summary", "generatedAt", "tags"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "question": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "insights": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/insight"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timelineItem"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "value", "unit", "delta", "trend"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "delta": {
          "type": "string"
        },
        "trend": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "insight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "title", "body", "confidence", "evidence", "tone"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tone": {
          "enum": ["signal", "risk", "decision"]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "detail", "kind"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        }
      }
    },
    "timelineItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "when", "title", "detail", "state"],
      "properties": {
        "id": {
          "type": "string"
        },
        "when": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "state": {
          "enum": ["complete", "current", "next"]
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "detail", "owner", "state"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "state": {
          "enum": ["ready", "blocked", "later"]
        }
      }
    }
  }
}
